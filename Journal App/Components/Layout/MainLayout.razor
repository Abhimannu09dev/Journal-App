@inherits LayoutComponentBase
@using Journal_App.Services
@implements IDisposable

@inject ThemeService ThemeService
@inject UserSettingsService SettingsService
@inject IJSRuntime JS

<div class="app-layout">
    <NavMenu />

    <main class="content">
        @Body
    </main>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        // Subscribe to theme changes
        ThemeService.ThemeChanged += OnThemeChanged;

        // Load saved theme from database
        var settings = await SettingsService.GetSettingsAsync();
        var savedTheme = string.IsNullOrWhiteSpace(settings.ThemeMode)
            ? "system"
            : settings.ThemeMode;

        // Apply globally (MAUI)
        ThemeService.Apply(savedTheme);

        // Apply to CSS immediately (in case JS runs before event fires)
        await ApplyThemeToCssAsync(savedTheme);
    }

    private async void OnThemeChanged(string mode)
    {
        await ApplyThemeToCssAsync(mode);
        StateHasChanged();
    }

    private async Task ApplyThemeToCssAsync(string mode)
    {
        try
        {
            await JS.InvokeVoidAsync("journalTheme.setTheme", mode);
        }
        catch (JSException)
        {
            // JS runtime not ready yet (e.g. called before WebView fully loaded).
            // The theme.js script will apply the correct class on its own load.
        }
        catch (TaskCanceledException)
        {
            // Component disposed during navigation — safe to ignore.
        }
    }

    public void Dispose()
    {
        ThemeService.ThemeChanged -= OnThemeChanged;
    }
}
