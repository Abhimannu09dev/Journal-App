@using Microsoft.AspNetCore.Components.Routing
@implements IDisposable
@inject NavigationManager Nav
@inject Journal_App.Services.AuthStateService AuthState
@inject Journal_App.Services.UserSettingsService SettingsService

@if (!AuthState.IsLoggedIn)
{
    <!-- When logged out, do not render the nav menu -->
    <header class="appbar navbar navbar-dark px-3">
        <a class="navbar-brand" href="">Journal App</a>
    </header>
}
else
{
    <!-- Top bar -->
    <header class="appbar navbar navbar-dark px-3">
        <button class="btn btn-dark me-2 d-md-none"
                type="button"
                @onclick="ToggleMenu"
                aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <a class="navbar-brand" href="">Journal App</a>

        <div class="ms-auto d-flex align-items-center text-white small">
            <span class="bi bi-person-circle me-2"></span>
            @username
        </div>
    </header>

    <!-- Nav drawer / sidebar -->
    <div class="nav-shell">
        <nav class="@NavCssClass">
            <div class="px-3 pt-3">

                <NavLink class="nav-link"
                         href="dashboard"
                         Match="NavLinkMatch.All"
                         @onclick="CloseMenuOnMobile">
                    <span class="bi bi-house-door-fill me-2"></span>
                    Dashboard
                </NavLink>

                <NavLink class="nav-link"
                         href="journal"
                         @onclick="CloseMenuOnMobile">
                    <span class="bi bi-journal-text me-2"></span>
                    My Journal
                </NavLink>

                <NavLink class="nav-link"
                         href="calendar"
                         @onclick="CloseMenuOnMobile">
                    <span class="bi bi-calendar-day me-2"></span>
                    Calendar
                </NavLink>
                <NavLink class="nav-link"
                         href="export"
                         @onclick="CloseMenuOnMobile">
                    <span class="bi bi-calendar-day me-2"></span>
                    Export
                </NavLink>

                <NavLink class="nav-link"
                         href="streaks"
                         @onclick="CloseMenuOnMobile">
                    <span class="bi bi-graph-up me-2"></span>
                    Streaks
                </NavLink>

                <NavLink class="nav-link"
                         href="settings"
                         @onclick="CloseMenuOnMobile">
                    <span class="bi bi-gear me-2"></span>
                    Settings
                </NavLink>

                <hr />

                <button class="nav-link btn btn-link text-start"
                        @onclick="Logout">
                    <span class="bi bi-box-arrow-left me-2"></span>
                    Logout
                </button>

            </div>
        </nav>

        <!-- Backdrop for mobile -->
        <div class="@BackdropCssClass" @onclick="ToggleMenu"></div>
    </div>
}

@code {
    private bool _isMenuOpen;
    private string username = "User";

    private string NavCssClass => _isMenuOpen ? "appnav open" : "appnav";

    private string BackdropCssClass => _isMenuOpen ? "backdrop show d-md-none" : "backdrop d-md-none";

    protected override async Task OnInitializedAsync()
    {
        AuthState.StateChanged += HandleAuthStateChanged;
        SettingsService.SettingsChanged += HandleSettingsChanged;

        // Load username once at start (if already logged in)
        if (AuthState.IsLoggedIn)
            await LoadUsernameAsync();
    }

    private async Task LoadUsernameAsync()
    {
        try
        {
            var s = await SettingsService.GetSettingsAsync();
            username = string.IsNullOrWhiteSpace(s.Username) ? "User" : s.Username;
        }
        catch
        {
            username = "User";
        }
    }

    private void HandleAuthStateChanged()
    {
        _isMenuOpen = false;

        // When user logs in, fetch username and refresh UI
        _ = InvokeAsync(async () =>
        {
            if (AuthState.IsLoggedIn)
                await LoadUsernameAsync();

            StateHasChanged();
        });
    }

    private void HandleSettingsChanged()
    {
        // Username could have changed in Settings page
        _ = InvokeAsync(async () =>
        {
            if (AuthState.IsLoggedIn)
                await LoadUsernameAsync();

            StateHasChanged();
        });
    }

    private void ToggleMenu() => _isMenuOpen = !_isMenuOpen;

    private void CloseMenuOnMobile() => _isMenuOpen = false;

    private void Logout()
    {
        _isMenuOpen = false;
        AuthState.Logout();
        Nav.NavigateTo("/login", replace: true);
    }

    public void Dispose()
    {
        AuthState.StateChanged -= HandleAuthStateChanged;
        SettingsService.SettingsChanged -= HandleSettingsChanged;
    }
}
