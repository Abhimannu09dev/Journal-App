@page "/export"
@using System.Globalization
@using Journal_App.Services.Export
@using CommunityToolkit.Maui.Storage
@inject IJournalService JournalService
@inject IExportService ExportService
@inject AuthStateService AuthState
@inject NavigationManager Nav

<div class="container py-4" style="max-width: 900px;">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h2 class="mb-1">Export Entries</h2>
            <div class="text-secondary">Export multiple journal entries as a privacy-safe PDF.</div>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" @onclick="GoCalendar">
                <span class="bi bi-calendar3 me-2"></span>Calendar
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="alert @statusClass" role="alert">
            @statusMessage
        </div>
    }

    <!-- Date Range -->
    <div class="card p-3 mb-3">
        <div class="fw-semibold mb-2">Date Range</div>

        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Start Date</label>
                <input class="form-control" type="date" @bind="startDate" />
            </div>

            <div class="col-md-6">
                <label class="form-label">End Date</label>
                <input class="form-control" type="date" @bind="endDate" />
            </div>
        </div>

        <div class="text-secondary small mt-2">
            Future dates are not allowed. Start date must be before or equal to end date.
        </div>
    </div>

    <!-- Privacy Options -->
    <div class="card p-3 mb-3">
        <div class="fw-semibold mb-2">Privacy-Safe Options</div>

        <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" id="safeMode" @bind="options.PrivacySafeMode" />
            <label class="form-check-label" for="safeMode">
                Privacy Safe Mode (exports only dates; no title, moods, tags, or content)
            </label>
        </div>

        <hr />

        <div class="row g-2">
            <div class="col-md-6">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="incTitle"
                           @bind="options.IncludeTitle" disabled="@options.PrivacySafeMode" />
                    <label class="form-check-label" for="incTitle">Include title</label>
                </div>

                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="incMoods"
                           @bind="options.IncludeMoods" disabled="@options.PrivacySafeMode" />
                    <label class="form-check-label" for="incMoods">Include moods</label>
                </div>
            </div>

            <div class="col-md-6">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="incTags"
                           @bind="options.IncludeTags" disabled="@options.PrivacySafeMode" />
                    <label class="form-check-label" for="incTags">Include tags</label>
                </div>

                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="incContent"
                           @bind="options.IncludeContent" disabled="@options.PrivacySafeMode" />
                    <label class="form-check-label" for="incContent">Include content</label>
                </div>
            </div>
        </div>
    </div>

    <!-- Export actions -->
    <div class="d-flex gap-2">
        <button class="btn btn-primary" @onclick="ExportPdf" disabled="@isBusy">
            <span class="bi bi-download me-2"></span>Export PDF
        </button>

        <button class="btn btn-outline-secondary" @onclick="GoCalendar" disabled="@isBusy">
            Cancel
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(lastExportPath))
    {
        <div class="card p-3 mt-3">
            <div class="fw-semibold mb-1">Last Export</div>
            <div class="small text-secondary">Saved to:</div>
            <div class="small" style="word-break: break-all;">
                @lastExportPath
            </div>
        </div>
    }
</div>

@code {
    private bool isBusy = false;
    private DateTime startDate = DateTime.Today;
    private DateTime endDate = DateTime.Today;

    private ExportOptions options = new();

    private string statusMessage = "";
    private string statusClass = "alert-secondary";

    private string lastExportPath = "";

    protected override void OnInitialized()
    {
        if (!AuthState.IsAuthenticated)
        {
            Nav.NavigateTo("/login", replace: true);
            return;
        }
        var today = DateTime.Today;
        startDate = new DateTime(today.Year, today.Month, 1);
        endDate = today;
    }

    private async Task ExportPdf()
    {
        if (isBusy) return;
        isBusy = true;
        SetStatus("", "alert-secondary");

        try
        {
            // Validation
            if (startDate.Date > endDate.Date)
            {
                SetStatus("Start date must be before or equal to end date.", "alert-warning");
                return;
            }

            if (endDate.Date > DateTime.Today.Date)
            {
                SetStatus("Future dates are not allowed.", "alert-warning");
                return;
            }

            var startKey = startDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
            var endKey = endDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);

            // Fetch entries
            var entries = await JournalService.GetEntriesByDateRangeAsync(startKey, endKey);

            if (entries == null || entries.Count == 0)
            {
                SetStatus("No entries found in the selected date range.", "alert-warning");
                return;
            }

            // Export 
            var (fileName, bytes) = await ExportService.ExportEntriesPdfAsync(entries, startKey, endKey, options);

            // Let user choose save location
            using var ms = new MemoryStream(bytes);
            var result = await FileSaver.Default.SaveAsync(fileName, ms, CancellationToken.None);

            if (result.IsSuccessful)
            {
                lastExportPath = result.FilePath ?? "";
                SetStatus($"Export complete. Saved to: {result.FilePath}", "alert-success");
            }
            else
            {
                SetStatus("Export canceled.", "alert-warning");
            }
        }
        catch (Exception ex)
        {
            SetStatus($"Export failed: {ex.Message}", "alert-danger");
        }
        finally
        {
            isBusy = false;
        }
    }

    private void GoCalendar() => Nav.NavigateTo("/calendar");

    private void SetStatus(string message, string cssClass)
    {
        statusMessage = message;
        statusClass = cssClass;
    }
}
