@page "/journal"
@using Journal_App.Entities
@using Journal_App.Services
@inject IJournalService JournalService
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="container py-4" style="max-width: 900px;">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-0">Journal</h2>
            <div class="text-secondary">All entries</div>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" @onclick="ReloadAsync" disabled="@isBusy">
                Reload
            </button>
            <button class="btn btn-primary" @onclick="GoToToday" disabled="@isBusy">
                + Write Today
            </button>
        </div>
    </div>

    <!-- SEARCH -->
    <div class="mb-3">
        <input class="form-control"
               placeholder="Search by title..."
               @bind="searchQuery"
               @bind:event="oninput" />
    </div>

    <!-- STATUS -->
    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="alert @statusClass py-2" role="alert">
            @statusMessage
        </div>
    }

    <!-- CONTENT -->
    @if (isBusy)
    {
        <div class="text-secondary">Loading...</div>
    }
    else if (FilteredEntries.Count == 0)
    {
        <div class="text-secondary">No entries found.</div>
    }
    else
    {
        <div class="list-group">
            @foreach (var e in PagedEntries)
            {
                <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-start gap-3 mt-1">

                        <button class="btn btn-link text-start p-0 flex-grow-1"
                                style="text-decoration:none;"
                                @onclick="() => OpenPreview(e)">
                            <div class="fw-semibold">@e.Title</div>
                            <div class="text-secondary small">@e.EntryDate</div>
                        </button>

                        <div class="d-flex flex-column align-items-end gap-2" style="min-width: 160px;">
                            <div class="text-secondary small">@e.WordCount words</div>

                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-outline-primary"
                                        @onclick="() => OpenPreview(e)">
                                    Read
                                </button>

                                <button class="btn btn-sm btn-outline-danger"
                                        disabled="@(!CanDelete(e))"
                                        @onclick="() => DeleteEntryAsync(e)">
                                    Delete
                                </button>
                            </div>

                            @if (!CanDelete(e))
                            {
                                <div class="text-secondary small">(Today only)</div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- PAGINATION -->
        <div class="d-flex justify-content-between align-items-center mt-3">
            <div class="text-secondary small">
                Showing @StartItem - @EndItem of @FilteredEntries.Count
            </div>

            <div class="btn-group">
                <button class="btn btn-outline-secondary"
                        disabled="@(currentPage <= 1)"
                        @onclick="PrevPage">
                    Prev
                </button>

                <button class="btn btn-outline-secondary disabled">
                    Page @currentPage / @TotalPages
                </button>

                <button class="btn btn-outline-secondary"
                        disabled="@(currentPage >= TotalPages)"
                        @onclick="NextPage">
                    Next
                </button>
            </div>
        </div>
    }
</div>

@code {
    private List<JournalEntry> entries = new();
    private string searchQuery = "";

    private bool isBusy = false;
    private string statusMessage = "";
    private string statusClass = "alert-secondary";

    private const int PageSize = 10;
    private int currentPage = 1;

    private List<JournalEntry> FilteredEntries =>
        string.IsNullOrWhiteSpace(searchQuery)
            ? entries
            : entries.Where(e =>
                !string.IsNullOrWhiteSpace(e.Title) &&
                e.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase))
            .ToList();

    private int TotalPages =>
        Math.Max(1, (int)Math.Ceiling(FilteredEntries.Count / (double)PageSize));

    private IEnumerable<JournalEntry> PagedEntries =>
        FilteredEntries
            .Skip((currentPage - 1) * PageSize)
            .Take(PageSize);

    private int StartItem =>
        FilteredEntries.Count == 0 ? 0 : ((currentPage - 1) * PageSize) + 1;

    private int EndItem =>
        Math.Min(currentPage * PageSize, FilteredEntries.Count);

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        isBusy = true;
        ClearStatus();

        entries = await JournalService.GetEntriesAsync();
        currentPage = 1;

        isBusy = false;
    }

    private void PrevPage() => currentPage--;
    private void NextPage() => currentPage++;

    private void GoToToday()
    {
        var key = DateTime.Today.ToString("yyyy-MM-dd");
        Nav.NavigateTo($"/journal/entry/{key}");
    }

    private void OpenPreview(JournalEntry entry)
    {
        Nav.NavigateTo($"/journal/preview/{entry.EntryDate}");
    }

    private bool CanDelete(JournalEntry e)
    {
        var todayKey = DateTime.Today.ToString("yyyy-MM-dd");
        return e.EntryDate == todayKey;
    }

    private async Task DeleteEntryAsync(JournalEntry entry)
    {
        var confirm = await JS.InvokeAsync<bool>("confirm", "Delete this entry?");
        if (!confirm) return;

        await JournalService.DeleteEntryAsync(entry.Id);
        entries = await JournalService.GetEntriesAsync();
        currentPage = 1;
    }

    private void ClearStatus()
    {
        statusMessage = "";
        statusClass = "alert-secondary";
    }
}
