@page "/journal"
@using Journal_App.Entities
@using Journal_App.Services
@inject IJournalService JournalService
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="container py-4" style="max-width: 900px;">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-0">Journal</h2>
            <div class="text-secondary">All entries</div>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" @onclick="ReloadAsync" disabled="@isBusy">Reload</button>
            <button class="btn btn-primary" @onclick="GoToToday" disabled="@isBusy">+ Write Today</button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="alert @statusClass py-2" role="alert">@statusMessage</div>
    }

    @if (isBusy)
    {
        <div class="text-secondary">Loading...</div>
    }
    else if (entries.Count == 0)
    {
        <div class="text-secondary">No entries yet.</div>
    }
    else
    {
        <div class="list-group">
            @foreach (var e in entries)
            {
                <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <button class="btn btn-link text-start p-0 flex-grow-1"
                                style="text-decoration:none;"
                                @onclick="() => OpenEntry(e.EntryDate)"
                                disabled="@isBusy">
                            <div class="fw-semibold">@e.Title</div>
                            <div class="text-secondary small">@e.EntryDate</div>
                            <div class="text-secondary small mt-1">@e.WordCount words</div>
                        </button>

                        <div class="d-flex flex-column align-items-end gap-2" style="min-width: 160px;">
                            <button class="btn btn-sm btn-outline-primary"
                                    @onclick="() => OpenEntry(e.EntryDate)"
                                    disabled="@isBusy">
                                Open
                            </button>

                            <button class="btn btn-sm btn-outline-danger"
                                    @onclick="() => DeleteEntryAsync(e)"
                                    disabled="@isBusy || !CanDelete(e)">
                                Delete (Today only)
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<JournalEntry> entries = new();
    private bool isBusy = false;

    private string statusMessage = "";
    private string statusClass = "alert-secondary";

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        isBusy = true;
        ClearStatus();

        try
        {
            entries = await JournalService.GetEntriesAsync();
        }
        catch (Exception ex)
        {
            SetStatus("Failed to load entries. " + ex.Message, "alert-danger");
        }
        finally
        {
            isBusy = false;
        }
    }

    private void GoToToday()
    {
        var todayKey = DateTime.Today.ToString("yyyy-MM-dd");
        Nav.NavigateTo($"/journal/entry/{todayKey}");
    }

    private void OpenEntry(string dateKey)
    {
        Nav.NavigateTo($"/journal/entry/{dateKey}");
    }

    private bool CanDelete(JournalEntry e)
    {
        var todayKey = DateTime.Today.ToString("yyyy-MM-dd");
        return string.Equals(e.EntryDate, todayKey, StringComparison.Ordinal);
    }

    private async Task DeleteEntryAsync(JournalEntry entry)
    {
        if (entry is null) return;

        var confirm = await JS.InvokeAsync<bool>("confirm", "Delete this entry? This cannot be undone.");
        if (!confirm) return;

        isBusy = true;
        ClearStatus();

        try
        {
            var ok = await JournalService.DeleteEntryAsync(entry.Id);
            if (!ok)
            {
                SetStatus("Delete failed.", "alert-danger");
                return;
            }

            SetStatus("Deleted.", "alert-success");
            entries = await JournalService.GetEntriesAsync();
        }
        catch (Exception ex)
        {
            SetStatus("Delete failed. " + ex.Message, "alert-danger");
        }
        finally
        {
            isBusy = false;
        }
    }

    private void SetStatus(string message, string cssClass)
    {
        statusMessage = message;
        statusClass = cssClass;
    }

    private void ClearStatus()
    {
        statusMessage = "";
        statusClass = "alert-secondary";
    }
}
