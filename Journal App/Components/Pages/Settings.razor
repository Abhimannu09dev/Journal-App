@page "/settings"
@using System.Linq
@inject UserSettingsService SettingsService
@inject ThemeService ThemeService
@inject IJSRuntime JS

<h3 class="mb-3">Settings</h3>

@if (isLoading)
{
    <p class="text-secondary">Loading settings...</p>
}
else
{
    <!-- USERNAME -->
    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title mb-3">Username</h5>

            <div class="mb-2">
                <label class="form-label">Current Username</label>
                <input class="form-control" value="@currentUsername" disabled />
            </div>

            <div class="mb-2">
                <label class="form-label">New Username</label>
                <input class="form-control" @bind="newUsername" placeholder="Enter new username" />
            </div>

            <div class="mb-3">
                <label class="form-label">Current PIN (required)</label>
                <input class="form-control"
                       type="password"
                       maxlength="4"
                       @bind="pinForUsername"
                       placeholder="4-digit PIN" />
            </div>

            <button class="btn btn-primary"
                    @onclick="SaveUsername"
                    disabled="@isBusy">
                Save Username
            </button>

            @if (!string.IsNullOrWhiteSpace(usernameMessage))
            {
                <div class="mt-3 alert @UsernameAlertClass">@usernameMessage</div>
            }
        </div>
    </div>

    <!-- SECURITY -->
    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title mb-3">Security (PIN)</h5>

            <input class="form-control mb-2"
                   type="password"
                   maxlength="4"
                   @bind="currentPin"
                   placeholder="Current PIN" />

            <input class="form-control mb-2"
                   type="password"
                   maxlength="4"
                   @bind="newPin"
                   placeholder="New PIN" />

            <input class="form-control mb-2"
                   type="password"
                   maxlength="4"
                   @bind="confirmPin"
                   placeholder="Confirm new PIN" />

            <input class="form-control mb-2"
                   @bind="pinHint"
                   placeholder="PIN hint (do not reveal PIN)" />

            <button class="btn btn-warning"
                    @onclick="SavePin"
                    disabled="@isBusy">
                Update PIN
            </button>

            @if (!string.IsNullOrWhiteSpace(pinMessage))
            {
                <div class="mt-3 alert @PinAlertClass">@pinMessage</div>
            }
        </div>
    </div>

    <!-- THEME (LIGHT / DARK only) -->
    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title mb-3">Theme</h5>

            <div class="form-check mb-2">
                <input class="form-check-input"
                       type="radio"
                       name="themeMode"
                       value="light"
                       checked="@(themeMode == "light")"
                       @onchange='() => ChangeTheme("light")' />
                <label class="form-check-label">Light mode</label>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input"
                       type="radio"
                       name="themeMode"
                       value="dark"
                       checked="@(themeMode == "dark")"
                       @onchange='() => ChangeTheme("dark")' />
                <label class="form-check-label">Dark mode</label>
            </div>

            <div class="text-secondary small">
                Theme is saved and applied globally.
            </div>

            @if (!string.IsNullOrWhiteSpace(themeMessage))
            {
                <div class="mt-3 alert @ThemeAlertClass">@themeMessage</div>
            }
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool isBusy = false;

    private string currentUsername = "";
    private string newUsername = "";
    private string pinForUsername = "";

    private string currentPin = "";
    private string newPin = "";
    private string confirmPin = "";
    private string pinHint = "";

    // Only "light" or "dark"
    private string themeMode = "light";

    private string usernameMessage = "";
    private string pinMessage = "";
    private string themeMessage = "";

    private bool usernameSuccess;
    private bool pinSuccess;
    private bool themeSuccess;

    private string UsernameAlertClass => usernameSuccess ? "alert-success" : "alert-danger";
    private string PinAlertClass => pinSuccess ? "alert-success" : "alert-danger";
    private string ThemeAlertClass => themeSuccess ? "alert-success" : "alert-danger";

    protected override async Task OnInitializedAsync()
    {
        var s = await SettingsService.GetSettingsAsync();

        currentUsername = s.Username ?? "User";

        // Force to light/dark only (fallback to light)
        var saved = (s.ThemeMode ?? "").Trim().ToLowerInvariant();
        themeMode = saved == "dark" ? "dark" : "light";

        pinHint = s.PinHint ?? "";

        // Apply immediately when opening settings (keeps UI consistent)
        ThemeService.Apply(themeMode);
        await JS.InvokeVoidAsync("journalTheme.setTheme", themeMode);

        isLoading = false;
    }

    private async Task ChangeTheme(string mode)
    {
        themeMessage = "";
        themeMode = mode;
        isBusy = true;

        try
        {
            // Save in DB
            await SettingsService.UpdateThemeAsync(mode);

            // Apply MAUI theme
            ThemeService.Apply(mode);

            // Apply Blazor CSS theme
            await JS.InvokeVoidAsync("journalTheme.setTheme", mode);

            themeSuccess = true;
            themeMessage = $"Theme changed to {mode}.";
        }
        catch (Exception ex)
        {
            themeSuccess = false;
            themeMessage = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task SaveUsername()
    {
        usernameMessage = "";

        if (string.IsNullOrWhiteSpace(newUsername))
        {
            usernameSuccess = false;
            usernameMessage = "Enter a new username.";
            return;
        }

        if (!IsFourDigitPin(pinForUsername))
        {
            usernameSuccess = false;
            usernameMessage = "Enter your current 4-digit PIN.";
            return;
        }

        isBusy = true;

        try
        {
            await SettingsService.UpdateUsernameAsync(pinForUsername, newUsername.Trim());

            currentUsername = newUsername.Trim();
            newUsername = "";
            pinForUsername = "";

            usernameSuccess = true;
            usernameMessage = "Username updated.";
        }
        catch (Exception ex)
        {
            usernameSuccess = false;
            usernameMessage = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task SavePin()
    {
        pinMessage = "";

        if (!IsFourDigitPin(currentPin))
        {
            pinSuccess = false;
            pinMessage = "Enter your current 4-digit PIN.";
            return;
        }

        if (!IsFourDigitPin(newPin))
        {
            pinSuccess = false;
            pinMessage = "New PIN must be exactly 4 digits.";
            return;
        }

        if (newPin != confirmPin)
        {
            pinSuccess = false;
            pinMessage = "PINs do not match.";
            return;
        }

        isBusy = true;

        try
        {
            await SettingsService.UpdatePinAsync(currentPin, newPin, pinHint.Trim());

            currentPin = "";
            newPin = "";
            confirmPin = "";

            pinSuccess = true;
            pinMessage = "PIN updated.";
        }
        catch (Exception ex)
        {
            pinSuccess = false;
            pinMessage = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private static bool IsFourDigitPin(string value)
        => !string.IsNullOrWhiteSpace(value) && value.Length == 4 && value.All(char.IsDigit);
}
