@page "/journal/preview/{dateKey}"
@using System.Globalization
@using Journal_App.Entities
@using Journal_App.Services
@using Markdig
@inject IJournalService JournalService
@inject NavigationManager Nav

<div class="container py-4" style="max-width: 900px;">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h2 class="mb-1">@title</h2>
            <div class="text-secondary">@dateDisplay</div>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" @onclick="GoBack">
                Back
            </button>

            @if (canEdit)
            {
                <button class="btn btn-primary" @onclick="GoEdit">
                    Edit
                </button>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="alert @statusClass" role="alert">@statusMessage</div>
    }

    @if (isLoading)
    {
        <div class="text-secondary">Loading...</div>
    }
    else if (!isValidDate)
    {
        <div class="card p-4">
            <p class="mb-0">Invalid date format. Use <strong>yyyy-MM-dd</strong>.</p>
        </div>
    }
    else if (entry is null)
    {
        <div class="card p-4">
            <p class="mb-0">No entry saved for this date.</p>
        </div>
    }
    else
    {
        <div class="card p-4">
            <div class="journal-preview">
                @((MarkupString)Markdown.ToHtml(entry.Content ?? "", pipeline))
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string dateKey { get; set; } = "";

    private bool isLoading = true;
    private bool isValidDate = true;
    private bool canEdit = false;

    private JournalEntry? entry;

    private string title = "Journal Preview";
    private string dateDisplay = "";

    private string statusMessage = "";
    private string statusClass = "alert-secondary";

    private DateTime selectedDate;
    private string selectedDateKey = "";

    private readonly MarkdownPipeline pipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .Build();

    protected override async Task OnParametersSetAsync()
    {
        ResetState();

        if (!TryParseDateKey(dateKey, out selectedDate))
        {
            isValidDate = false;
            isLoading = false;
            return;
        }

        selectedDateKey = selectedDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
        dateDisplay = selectedDate.ToString("dddd, MMMM dd, yyyy", CultureInfo.InvariantCulture);

        var todayKey = DateTime.Today.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
        canEdit = (selectedDateKey == todayKey);

        isLoading = true;

        try
        {
            entry = await JournalService.GetEntryByDateAsync(selectedDateKey);
            title = (entry == null || string.IsNullOrWhiteSpace(entry.Title)) ? "Untitled Entry" : entry.Title;
        }
        catch (Exception ex)
        {
            statusMessage = "Failed to load entry. " + ex.Message;
            statusClass = "alert-danger";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoEdit() => Nav.NavigateTo($"/journal/entry/{selectedDateKey}");
    private void GoBack() => Nav.NavigateTo("/journal");

    private void ResetState()
    {
        isLoading = true;
        isValidDate = true;
        canEdit = false;

        entry = null;
        title = "Journal Preview";
        dateDisplay = "";

        statusMessage = "";
        statusClass = "alert-secondary";

        selectedDate = default;
        selectedDateKey = "";
    }

    private static bool TryParseDateKey(string? key, out DateTime date)
    {
        return DateTime.TryParseExact(
            key ?? "",
            "yyyy-MM-dd",
            CultureInfo.InvariantCulture,
            DateTimeStyles.None,
            out date
        );
    }
}
