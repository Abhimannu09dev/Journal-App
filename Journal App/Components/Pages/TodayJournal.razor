@page "/journal/entry/{dateKey}"
@using Journal_App.Entities
@using Journal_App.Services
@inject IJournalService JournalService
@inject NavigationManager Nav

<h3>Journal Entry</h3>

<input class="form-control mb-2"
       placeholder="Title"
       @bind="model.Title" />

<textarea class="form-control mb-2"
          rows="8"
          placeholder="Markdown content..."
          @bind="model.Content"></textarea>

<div class="mb-2">
    <label class="form-label">Tags (comma separated)</label>
    <input class="form-control"
           placeholder="Work, Health, Reflection"
           @bind="tagsInput" />
</div>

<button class="btn btn-primary" @onclick="SaveAsync">
    Save
</button>

@code {
    [Parameter] public string dateKey { get; set; } = "";

    private JournalEntry model = new();
    private string tagsInput = "";

    protected override async Task OnInitializedAsync()
    {
        var entry = await JournalService.GetEntryByDateAsync(dateKey);
        if (entry != null)
        {
            model = entry;
            tagsInput = string.Join(",",
                entry.EntryTags.Select(t => t.Tag!.Name));
        }
    }

    private async Task SaveAsync()
    {
        if (model.Id == 0)
        {
            var res = await JournalService.CreateEntryAsync(
                DateTime.Parse(dateKey),
                model.Title,
                model.Content,
                "markdown");

            if (!res.ok) return;

            model = await JournalService.GetEntryByDateAsync(dateKey) ?? model;
        }
        else
        {
            await JournalService.UpdateEntryAsync(
                model.Id,
                model.Title,
                model.Content,
                "markdown");
        }

        var tags = tagsInput.Split(',')
            .Select(t => t.Trim())
            .ToList();

        await JournalService.SetEntryTagsAsync(model.Id, tags);
    }
}
